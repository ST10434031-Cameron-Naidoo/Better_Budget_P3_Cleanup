<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@color/card_white"
    app:cardCornerRadius="15dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- EMOJI ICON — larger -->
        <TextView
            android:id="@+id/tvGoalIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:textSize="36sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- CATEGORY TITLE -->
        <TextView
            android:id="@+id/tvGoalTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/brand_mid_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvGoalIcon"
            app:layout_constraintEnd_toStartOf="@+id/llGoalActions"
            app:layout_constraintStart_toEndOf="@id/tvGoalIcon"
            app:layout_constraintTop_toTopOf="@id/tvGoalIcon"/>

        <TextView
            android:id="@+id/tvGoalDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/hint_grey"
            android:textSize="11sp"
            app:layout_constraintStart_toEndOf="@id/tvGoalIcon"
            app:layout_constraintTop_toBottomOf="@id/tvGoalTitle"
            app:layout_constraintEnd_toStartOf="@+id/llGoalActions"
            android:text="Set on: 01 Jan 2026"/>

        <!-- EDIT / DELETE ACTIONS -->
        <LinearLayout
            android:id="@+id/llGoalActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivEditGoal"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/brand_mid_blue"/>

            <ImageView
                android:id="@+id/ivDeleteGoal"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/brand_button_red"/>

        </LinearLayout>

        <!-- TOTAL SPENT ROW -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_marginTop="16dp"
            android:text="Total Spent:"
            android:fontFamily="sans-serif"
            android:textColor="@color/hint_grey"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvCurrentAmount"
            app:layout_constraintEnd_toStartOf="@id/tvCurrentAmount"
            app:layout_constraintTop_toTopOf="@id/tvCurrentAmount"/>

        <TextView
            android:id="@+id/tvCurrentAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/brand_mid_blue"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llGoalActions"/>

        <!-- PROGRESS BAR — bigger -->
        <ProgressBar
            android:id="@+id/goalProgressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="18dp"
            android:layout_marginTop="10dp"
            android:progressTint="@color/brand_mid_blue"
            android:progressBackgroundTint="#E0E0E0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCurrentAmount"/>

        <!-- MIN GOAL -->
        <TextView
            android:id="@+id/tvMinGoal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/hint_grey"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/goalProgressBar"/>

        <!-- MAX GOAL -->
        <TextView
            android:id="@+id/tvTargetAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/hint_grey"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/goalProgressBar"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>