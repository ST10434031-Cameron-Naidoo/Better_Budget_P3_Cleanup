<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_background"
    tools:context=".ui.ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- HEADING -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PROFILE"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/text_white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="24dp"/>

        <!-- PROFILE PICTURE SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="24dp">

            <!-- PROFILE IMAGE -->
            <ImageView
                android:id="@+id/ivProfilePicture"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:background="@drawable/spinner_background"/>

            <!-- PHOTO BUTTONS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical"
                >

                <TextView
                    android:id="@+id/tvTakeProfilePicture"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="TAKE PHOTO"
                    android:fontFamily="@font/league_spartan_"
                    android:textColor="@color/text_white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@color/brand_deep_blue"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvUploadProfilePicture"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="ADD FROM GALLERY"
                    android:fontFamily="@font/league_spartan_"
                    android:textColor="@color/text_white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@color/brand_deep_blue"/>

            </LinearLayout>
        </LinearLayout>

        <!-- EMAIL -->
        <EditText
            android:id="@+id/etProfileEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/spinner_background"
            android:hint="Email Address*"
            android:padding="12dp"
            android:textColorHint="@color/hint_grey"
            android:textColor="@color/text_navy"
            android:fontFamily="sans-serif"
            android:inputType="textEmailAddress"/>

        <!-- FIRST NAME -->
        <EditText
            android:id="@+id/etProfileFirstName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/spinner_background"
            android:hint="First Name"
            android:padding="12dp"
            android:textColorHint="@color/hint_grey"
            android:textColor="@color/text_navy"
            android:fontFamily="sans-serif"/>

        <!-- LAST NAME -->
        <EditText
            android:id="@+id/etProfileLastName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/spinner_background"
            android:hint="Last Name"
            android:padding="12dp"
            android:textColorHint="@color/hint_grey"
            android:textColor="@color/text_navy"
            android:fontFamily="sans-serif"/>

        <!-- DATE OF BIRTH LABEL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date of Birth"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"/>

        <!-- DATE SPINNERS -->
        <LinearLayout
            android:id="@+id/datePickerLayout"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp">

            <Spinner
                android:id="@+id/spProfileDay"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_background"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/spProfileMonth"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_background"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/spProfileYear"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_background"/>

        </LinearLayout>

        <!-- AGE -->
        <TextView
            android:id="@+id/tvProfileAge"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/spinner_background"
            android:padding="12dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_navy"
            android:hint="Age"
            android:textColorHint="@color/hint_grey"/>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnProfileDelete"
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="DELETE"
                android:textColor="@color/text_white"
                android:fontFamily="@font/league_spartan_"
                android:textStyle="bold"
                android:backgroundTint="@color/brand_button_red"
                android:layout_marginEnd="16dp"/>

            <Button
                android:id="@+id/btnProfileUpdate"
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="UPDATE"
                android:textColor="@color/text_white"
                android:fontFamily="@font/league_spartan_"
                android:textStyle="bold"
                android:backgroundTint="@color/brand_mid_blue"/>

        </LinearLayout>
        <Button
            android:id="@+id/btnProfileLogOut"
            android:layout_width="256dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/league_spartan_"
            android:textStyle="bold"
            android:backgroundTint="@color/brand_button_red"
            android:text="LOGOUT"/>
    </LinearLayout>
</ScrollView>