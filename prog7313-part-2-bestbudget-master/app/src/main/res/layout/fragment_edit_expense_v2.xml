<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- HEADING -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EDIT EXPENSE"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/text_white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="32dp"/>

        <!-- CATEGORY SPINNER -->
        <Spinner
            android:id="@+id/spinnerEditExpenseCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/spinner_background"
            android:padding="12dp"/>

        <!-- SUBCATEGORY SPINNER -->
        <Spinner
            android:id="@+id/spinnerEditExpenseSubCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/spinner_background"
            android:padding="12dp"/>

        <!-- DATE LABEL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date *"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <!-- DATE ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="32dp">

            <EditText
                android:id="@+id/etEditExpenseDay"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_background"
                android:hint="DD"
                android:gravity="center"
                android:padding="12dp"
                android:inputType="number"
                android:maxLength="2"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_navy"
                android:textColorHint="@color/hint_grey"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:layout_gravity="center_vertical"/>

            <EditText
                android:id="@+id/etEditExpenseMonth"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_background"
                android:hint="MM"
                android:gravity="center"
                android:padding="12dp"
                android:inputType="number"
                android:maxLength="2"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_navy"
                android:textColorHint="@color/hint_grey"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:layout_gravity="center_vertical"/>

            <EditText
                android:id="@+id/etEditExpenseYear"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="2"
                android:background="@drawable/spinner_background"
                android:hint="YYYY"
                android:gravity="center"
                android:padding="12dp"
                android:inputType="number"
                android:maxLength="4"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_navy"
                android:textColorHint="@color/hint_grey"/>

        </LinearLayout>

        <!-- DESCRIPTION -->
        <EditText
            android:id="@+id/etEditExpenseDescription"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/spinner_background"
            android:hint="Description (optional)"
            android:padding="12dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_navy"
            android:textColorHint="@color/hint_grey"
            android:inputType="text"/>

        <!-- AMOUNT -->
        <EditText
            android:id="@+id/etEditExpenseAmount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/spinner_background"
            android:hint="Amount (R)*"
            android:padding="12dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_navy"
            android:textColorHint="@color/hint_grey"
            android:inputType="numberDecimal"/>

        <!-- AUTOMATE LABEL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Automate (optional)"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"/>

        <!-- AUTOMATE COMING SOON -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="— Coming in Part 3 —"
            android:fontFamily="sans-serif"
            android:textColor="@color/hint_grey"
            android:textSize="12sp"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/spinner_background"
            android:padding="12dp"
            android:alpha="0.6"/>

        <!-- PHOTO SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- PHOTO THUMBNAIL -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="12dp">

                <View
                    android:id="@+id/vEditPhotoPlaceholder"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/spinner_background"
                    android:alpha="0.3"/>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_camera"
                    android:contentDescription="Photo placeholder"
                    android:alpha="0.7"/>

                <ImageView
                    android:id="@+id/ivEditPhotoPreview"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Selected photo"
                    android:visibility="gone"/>

            </FrameLayout>

            <!-- PHOTO BUTTONS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnEditTakePhoto"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="TAKE PHOTO"
                    android:textColor="@color/text_white"
                    android:fontFamily="@font/league_spartan_"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/brand_mid_blue"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnEditAddFromGallery"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="ADD FROM GALLERY"
                    android:textColor="@color/text_white"
                    android:fontFamily="@font/league_spartan_"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/brand_mid_blue"/>

            </LinearLayout>
        </LinearLayout>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnEditExpenseCancel"
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="CANCEL"
                android:textColor="@color/text_white"
                android:fontFamily="@font/league_spartan_"
                android:textStyle="bold"
                android:backgroundTint="@color/brand_button_red"
                android:layout_marginEnd="16dp"/>

            <Button
                android:id="@+id/btnEditExpenseUpdate"
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="UPDATE"
                android:textColor="@color/text_white"
                android:fontFamily="@font/league_spartan_"
                android:textStyle="bold"
                android:backgroundTint="@color/brand_mid_blue"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>