<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- HEADING -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EDIT GOAL"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/text_white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="32dp"/>

        <!-- CATEGORY LABEL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:text="Category"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/text_white"
            android:textSize="12sp"/>

        <!-- CATEGORY — NON EDITABLE -->
        <TextView
            android:id="@+id/tvUpdateGoalCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/spinner_background"
            android:padding="12dp"
            android:fontFamily="@font/league_spartan_"
            android:textColor="@color/text_navy"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:text="Category Name"
            android:alpha="0.7"/>

        <!-- MIN GOAL -->
        <EditText
            android:id="@+id/etUpdateGoalMin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/spinner_background"
            android:hint="Update Minimum Target"
            android:padding="12dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_navy"
            android:textColorHint="@color/hint_grey"
            android:inputType="numberDecimal"/>

        <!-- MAX GOAL -->
        <EditText
            android:id="@+id/etUpdateGoalMax"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/spinner_background"
            android:hint="Update Maximum Limit*"
            android:padding="12dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_navy"
            android:textColorHint="@color/hint_grey"
            android:inputType="numberDecimal"/>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="40dp">

            <Button
                android:id="@+id/btnCancelUpdateGoal"
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="CANCEL"
                android:textColor="@color/text_white"
                android:fontFamily="@font/league_spartan_"
                android:textStyle="bold"
                android:backgroundTint="@color/brand_button_red"
                android:layout_marginEnd="16dp"/>

            <Button
                android:id="@+id/btnUpdateGoal"
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="UPDATE"
                android:textColor="@color/text_white"
                android:fontFamily="@font/league_spartan_"
                android:textStyle="bold"
                android:backgroundTint="@color/brand_mid_blue"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>